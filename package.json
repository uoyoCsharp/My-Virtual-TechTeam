{
  "name": "@uoyo/mvtt",
  "version": "2.0.0-beta.6",
  "description": "My Virtual Tech Team - AI-guided prompt orchestration framework",
  "type": "module",
  "bin": {
    "mvtt": "dist/index.js"
  },
  "files": [
    "dist/",
    "sources/",
    "registry.yaml",
    "install-manifest.yaml"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "agents",
    "prompt-engineering",
    "claude-code",
    "cli",
    "orchestration"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uoyoCsharp/My-Virtual-TechTeam.git"
  },
  "bugs": {
    "url": "https://github.com/uoyoCsharp/My-Virtual-TechTeam/issues"
  },
  "homepage": "https://github.com/uoyoCsharp/My-Virtual-TechTeam#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json && node build-scripts.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "prompts": "^2.4.2",
    "yaml": "^2.4.0"
  },
  "license": "MIT"
}
